{
  "bot": {
    "name": "MySmartPortfolio",
    "type": "smart_portfolio",
    "market": "spot"
  },
  "setup_mode": "manual",
  "portfolio": {
    "assets": [
      { "symbol": "BTC", "allocation_pct": 50.0 },
      { "symbol": "ETH", "allocation_pct": 50.0 }
    ],
    "total_usdt": 100.0
  },
  "rebalance": {
    "mode": "proportional",
    "proportional": {
      "threshold_pct": 5,
      "check_interval_minutes": 5,
      "min_deviation_to_execute_pct": 3
    },
    "timed": {
      "frequency": "daily"
    },
    "unbalanced": {}
  },
  "termination": {
    "sell_at_termination": false
  },
  "asset_transfer": {
    "enable_asset_transfer": false
  }
}
