{
  "_comment": "Smart Portfolio — Bitget-compatible configuration",

  "portfolio": {
    "min_coins": 2,
    "max_coins": 10,
    "quote_currency": "USDT",
    "market_type": "spot",

    "coins": [
      { "symbol": "BTC",  "target_percentage": 40.0 },
      { "symbol": "ETH",  "target_percentage": 30.0 },
      { "symbol": "SOL",  "target_percentage": 20.0 },
      { "symbol": "BNB",  "target_percentage": 10.0 }
    ],

    "equal_distribution": false
  },

  "investment": {
    "total_usdt": 1000.0,
    "enable_asset_transfer": true,
    "sell_at_termination": true
  },

  "rebalance_mode": "proportional",

  "proportional": {
    "deviation_threshold_pct": 5,
    "allowed_thresholds": [1, 3, 5]
  },

  "timed": {
    "interval": "weekly",
    "allowed_intervals": ["daily", "weekly", "monthly"]
  },

  "unbalanced": {
    "auto_rebalance": false
  },

  "trading": {
    "fee_rate": 0.001,
    "min_trade_usdt": 1.0,
    "futures_enabled": false
  }
}
