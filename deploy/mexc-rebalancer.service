[Unit]
Description=MEXC Smart Portfolio Rebalancer Bot
After=network.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/opt/mexc-rebalancer-bot
EnvironmentFile=/opt/mexc-rebalancer-bot/.env
ExecStart=/usr/bin/python3 -m uvicorn api.main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
