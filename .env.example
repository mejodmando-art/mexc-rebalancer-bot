MEXC_API_KEY=your_api_key_here
MEXC_SECRET_KEY=your_secret_key_here
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
API_URL=http://localhost:8000

# Supabase PostgreSQL – required for persistent storage on Railway
# Get from: Supabase → Settings → Database → Connection string → URI
DATABASE_URL=postgresql://postgres.xxxx:password@aws-1-eu-central-1.pooler.supabase.com:6543/postgres
