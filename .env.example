MEXC_API_KEY=your_api_key_here
MEXC_SECRET_KEY=your_secret_key_here
API_URL=http://localhost:8000

# API protection (recommended in production)
# Client sends: Authorization: Bearer <API_AUTH_KEY> or X-API-Key: <API_AUTH_KEY>
API_AUTH_KEY=change_this_to_a_long_random_secret

# CORS (comma-separated origins)
# Example: https://your-frontend.com,https://admin.your-frontend.com
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Optional: legacy Telegram fields (currently not used by backend runtime)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Supabase PostgreSQL – required for persistent storage on Railway
# Get from: Supabase → Settings → Database → Connection string → URI
DATABASE_URL=postgresql://postgres.xxxx:password@aws-1-eu-central-1.pooler.supabase.com:6543/postgres
