# ── مطلوب ─────────────────────────────────────────────────────────────────────

# توكن البوت من @BotFather على تيليجرام
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxYZ

# معرّف تيليجرام الخاص بك (من @userinfobot)
# يمكن إضافة أكثر من معرّف مفصولة بفاصلة: 111,222,333
ALLOWED_USER_IDS=123456789

# ── اختياري ───────────────────────────────────────────────────────────────────

# رابط PostgreSQL للحفظ الدائم (بدونه يستخدم SQLite محلياً)
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# مسار ملف SQLite (الافتراضي: bot.db في مجلد المشروع)
# DATABASE_PATH=bot.db

# عملة التسعير (الافتراضي: USDT)
# QUOTE_CURRENCY=USDT

# ── Web App API ────────────────────────────────────────────────────────────────

# مفتاح سري للـ Web App — الصفحة ترسله في كل طلب (X-API-Key header)
# غيّره لقيمة عشوائية قوية قبل النشر
WEB_APP_SECRET=change-me-to-something-random

# بورت Flask API (الافتراضي 8080)
# API_PORT=8080

# عنوان الـ Web App الكامل — يُستخدم في زر تيليجرام
# WEBAPP_URL=https://your-railway-app.up.railway.app/webapp/
